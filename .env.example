# ==================================================
# ACCOUNT
# ==================================================
ACCOUNT_BALANCE=100
ACCOUNT_CURRENCY=USD
ACCOUNT_LEVERAGE=100

TRADING_MODE=demo
IS_DEMO=true
ALLOW_REAL_TRADING=false
LEARN_ONLY=true

USER_ID=YOUR_MT5_LOGIN
PASSWORD=YOUR_MT5_PASSWORD
SERVER=YOUR_MT5_SERVER
SERVER_IP=

# ==================================================
# PAIR & TIMEFRAME
# ==================================================
TRADING_PAIRS=EURUSD.fl
TRADING_TIMEFRAMES=M1,M5,M15,M30,H1,H4
ADAPTIVE_TIMEFRAME=true
USE_MULTI_TIMEFRAME=true

# ==================================================
# RISK MANAGEMENT
# ==================================================
MAX_RISK_PCT=0.005
MAX_DAILY_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=1
RR_RATIO=2.0

USE_DYNAMIC_SL=true
USE_DYNAMIC_TP=true
SL_PIPS=30
TP_PIPS=60

TRAILING_ACTIVATE=20
TRAILING_DISTANCE=10
USE_DYNAMIC_RISK=true

# ==================================================
# EMERGENCY MODE
# ==================================================
EMERGENCY_CAUTION_DD=0.03
EMERGENCY_DANGER_DD=0.04
EMERGENCY_CRITICAL_DD=0.05
EMERGENCY_AUTO_CLOSE_POSITIONS=true
EMERGENCY_NOTIFY_TELEGRAM=true

# ==================================================
# AI FILTER
# ==================================================
MIN_CONFIDENCE=0.40
MIN_MARKET_SCORE=40
ALLOW_NO_TRADE=true
MAX_SPREAD_PIPS=2.0

# ==================================================
# SELF LEARNING
# ==================================================
ENABLE_SELF_LEARNING=true
ENABLE_AUTO_RETRAIN=true
RETRAIN_AFTER_TRADES=50
RETRAIN_INTERVAL_HOURS=24
MODEL_VERSIONING=true
CONCEPT_DRIFT_DETECTION=true
ADAPTIVE_MEMORY=true
WEIGHT_NEW_DATA=true

# ==================================================
# MACHINE LEARNING
# ==================================================
ENABLE_XGBOOST=true
ENABLE_RANDOM_FOREST=true
ENABLE_LIGHTGBM=true
ENABLE_LSTM=true
ENABLE_VOTING_ENSEMBLE=true

# ==================================================
# TRAINING
# ==================================================
CONFIRM_TRAINING=yes
HISTORICAL_YEARS=1
ROLLING_TRAINING_WINDOW_DAYS=365

# ==================================================
# MARKET ANALYSIS
# ==================================================
ENABLE_MARKET_STRUCTURE=true
ENABLE_SUPPORT_RESISTANCE=true
ENABLE_BREAKOUT_DETECTION=true
ENABLE_BREAKDOWN_DETECTION=true
ENABLE_PRICE_ACTION=true
ENABLE_CANDLE_PATTERN=true
ENABLE_VOLATILITY_ANALYSIS=true
ENABLE_TREND_ANALYSIS=true
ENABLE_MARKET_REGIME=true

# ==================================================
# NEWS ANALYSIS
# ==================================================
NEWS_ENABLED=true
NEWS_WEIGHT=0.15
NEWS_API_KEY=YOUR_NEWSAPI_KEY

# ==================================================
# LLM ANALYSIS
# ==================================================
ENABLE_LLM=true
LLM_WEIGHT=0.20
LLM_API_KEY=YOUR_GROQ_API_KEY
LLM_API_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ==================================================
# PROFIT TARGET
# ==================================================
PROFIT_TARGET_PERCENT=0.3

# ==================================================
# TELEGRAM
# ==================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

TELEGRAM_NOTIFY_OPEN=true
TELEGRAM_NOTIFY_CLOSE=true
TELEGRAM_NOTIFY_TRAILING=true
TELEGRAM_NOTIFY_EMERGENCY=true
TELEGRAM_NOTIFY_ERROR=true
TELEGRAM_NOTIFY_RETRAIN=true
TELEGRAM_NOTIFY_DAILY=true
TELEGRAM_NOTIFY_WEEKLY=true
TELEGRAM_NOTIFY_MONTHLY=true
TELEGRAM_NOTIFY_HEARTBEAT=true

# ==================================================
# BACKTEST
# ==================================================
ENABLE_WALK_FORWARD_TEST=true
ENABLE_MONTE_CARLO_TEST=true
ENABLE_OUT_OF_SAMPLE_TEST=true

# ==================================================
# LOGGING
# ==================================================
LOG_LEVEL=INFO
SAVE_AI_REASONING=true
SAVE_TRADE_HISTORY=true
SAVE_MARKET_STATE=true
SAVE_DECISION_LOG=true

# ==================================================
# DIAGNOSTIC
# ==================================================
SHOW_AI_CONFIDENCE=true
SHOW_MARKET_SCORE=true
SHOW_REGIME=true
SHOW_SELECTED_TIMEFRAME=true
SHOW_MODEL_VERSION=true
SHOW_LEARNING_STATUS=true
